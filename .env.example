# Web UI port
STRIXNOTE_WEB_PORT=8080

# Storage root (use /storage/transcribe for your VM; others can use ./data)
DATA_DIR=/storage/transcribe

# Meilisearch
# REQUIRED: Set a strong random string before first run.
# Example:
# openssl rand -hex 32
MEILI_MASTER_KEY=

# --- Whisper model selection ---
# Default (good balance on CPU):
WHISPER_MODEL=medium.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8

# ============================================================
# Model options - 
# If you use any option below comment out the defaults above
# ============================================================

# Smaller / faster (lower accuracy, good for weak CPUs):
# WHISPER_MODEL=base.en
# WHISPER_MODEL=small.en

# Larger / slower (higher accuracy, requires more RAM/VRAM):
# WHISPER_MODEL=large-v3
# WHISPER_MODEL=large-v3-turbo

# Multilingual (if you need non-English languages):
# WHISPER_MODEL=small
# WHISPER_MODEL=medium
# WHISPER_MODEL=large-v3

# ============================================================
# Device options
# ============================================================

# CPU (default, works everywhere):
# WHISPER_DEVICE=cpu

# NVIDIA GPU (requires CUDA + container GPU support):
# WHISPER_DEVICE=cuda

# Apple Silicon (Mac only):
# WHISPER_DEVICE=mps

# ============================================================
# Compute type options
# ============================================================

# CPU recommended:
# WHISPER_COMPUTE=int8        # Fastest CPU option (recommended)
# WHISPER_COMPUTE=int8_float32
# WHISPER_COMPUTE=float32     # Slow but highest precision

# CUDA GPU recommended:
# WHISPER_COMPUTE=float16     # Best balance on GPU
# WHISPER_COMPUTE=int8_float16
# WHISPER_COMPUTE=float32

# Notes:
# - int8 is strongly recommended for CPU.
# - float16 is strongly recommended for CUDA GPUs.
# - Larger models require significantly more RAM/VRAM.
# - Changing model/device/compute requires restart.

# After changing any Whisper setting:
# docker compose restart transcribe_worker